{
  "name": "craigs-autos-lead-platform",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "astro dev",
    "dev:chatkit": "node --env-file-if-exists=.env.local server/chatkit-dev.mjs",
    "dev:local": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:chatkit\" \"npm:dev\"",
    "typecheck:web": "npx astro sync && npx tsc --pretty false --noEmit -p tsconfig.json",
    "typecheck:node": "npx tsc --pretty false --noEmit -p tsconfig.node.json",
    "typecheck:backend:deploy": "npx tsc --pretty false --noEmit -p amplify/tsconfig.json",
    "typecheck:backend:tests": "npx tsc --pretty false --noEmit -p amplify/tsconfig.test.json",
    "typecheck:backend": "npm run typecheck:backend:deploy && npm run typecheck:backend:tests",
    "typecheck": "npm run typecheck:web && npm run typecheck:node && npm run typecheck:backend",
    "verify:backend-types": "npm run typecheck:backend",
    "verify:amplify-deploy-compiler": "node scripts/verify-amplify-deploy-compiler.mjs",
    "test:backend": "node --experimental-strip-types --test --test-concurrency=1 \"amplify/functions/**/*.test.ts\"",
    "verify:backend": "npm run typecheck:backend && npm run verify:amplify-deploy-compiler && npm run test:backend",
    "lint": "biome lint amplify/functions server scripts packages src/scripts",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false amplify/functions server scripts packages src/scripts",
    "deps:update": "zsh tools/deps-update.sh",
    "deps:update:clean": "zsh tools/deps-update-clean.sh",
    "seed:social-cards": "node scripts/seed-social-cards.mjs",
    "validate:i18n": "node scripts/validate-i18n.mjs",
    "validate:business-profile": "node scripts/validate-business-profile-usage.mjs",
    "validate:social": "node scripts/validate-social-cards.mjs",
    "validate:content": "npm run validate:i18n && npm run validate:social",
    "managed-conversions": "node --experimental-strip-types scripts/managed-conversions.ts",
    "managed-conversions:validate": "npm run managed-conversions -- validate",
    "managed-conversions:readiness": "npm run managed-conversions -- readiness",
    "managed-conversions:env-template": "npm run managed-conversions -- env-template",
    "generate:social-images": "node scripts/generate-social-images.mjs",
    "guard:build": "node scripts/build-guards.mjs",
    "guard:admin-build": "node scripts/guard-admin-build.mjs",
    "prepare:release-assets": "npm run generate:social-images && npm run guard:build",
    "predeploy": "npm run validate:business-profile && npm run typecheck && npm run verify:amplify-deploy-compiler && npm run test:backend && npm run lint && npm run format:check",
    "build": "rm -rf dist && astro build && npm run guard:admin-build",
    "build:release": "npm run validate:content && npm run prepare:release-assets && npm run build",
    "verify": "npm run predeploy && npm run build",
    "verify:release": "npm run predeploy && npm run build:release",
    "smoke:admin-leads": "node scripts/smoke-admin-leads.mjs",
    "smoke:chatkit": "node scripts/smoke-chatkit.mjs",
    "smoke:email-intake": "node --experimental-strip-types scripts/smoke-email-intake.ts",
    "smoke:lead-alerts": "node --experimental-strip-types scripts/smoke-lead-alerts.ts",
    "smoke:journey": "node --experimental-strip-types scripts/smoke-journey.ts",
    "sync:amplify-redirects": "node scripts/sync-amplify-redirects.mjs",
    "check:amplify-redirects": "node scripts/sync-amplify-redirects.mjs --check",
    "indexnow:submit": "node scripts/indexnow-submit.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@aws-sdk/client-dynamodb": "^3.1035.0",
    "@aws-sdk/client-lambda": "^3.1035.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-scheduler": "^3.1035.0",
    "@aws-sdk/client-sesv2": "^3.1035.0",
    "@aws-sdk/lib-dynamodb": "^3.1035.0",
    "@aws-sdk/s3-presigned-post": "^3.1035.0",
    "@craigs/business-profile": "file:packages/business-profile",
    "@craigs/contracts": "file:packages/contracts",
    "@openai/chatkit-react": "^1.5.0",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.1.9",
    "concurrently": "^9.2.1",
    "openai": "^6.34.0",
    "postal-mime": "^2.7.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "aws-cdk-lib": "^2.250.0",
    "constructs": "^10.6.0",
    "glob": "^13.0.6",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3"
  }
}
