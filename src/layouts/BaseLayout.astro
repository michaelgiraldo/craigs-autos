---
import ChatWidget from '../components/ChatWidget.astro';
import AnalyticsBody from './base/AnalyticsBody.astro';
import AnalyticsHead from './base/AnalyticsHead.astro';
import BaseLayoutScripts from './base/BaseLayoutScripts.astro';
import SeoMetaHead from './base/SeoMetaHead.astro';
import SiteFooter from './base/SiteFooter.astro';
import SiteHeader from './base/SiteHeader.astro';
import SiteMenu from './base/SiteMenu.astro';
import StickyCta from './base/StickyCta.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import '../styles/global.css';
import brandLogo from '../assets/brand/craigs-auto-upholstery-logo.png';
import { buildBaseLayoutContext } from './base/layout-context';

const layout = buildBaseLayoutContext({
  generator: Astro.generator,
  isProduction: import.meta.env.PROD,
  props: Astro.props,
  publicGtmId: import.meta.env.PUBLIC_GTM_ID,
  site: Astro.site,
});

const {
  brandName,
  canonicalPath,
  canonicalUrl,
  currentLanguageLabel,
  desktopNav,
  emailHref,
  generator,
  gtmAllowedOnPage,
  gtmId,
  gtmPageContext,
  hreflangLinks,
  languageLinks,
  lang,
  locale,
  localeBaseHref,
  mapsHref,
  mobilePrimaryNav,
  mobileSecondaryNav,
  navItems,
  noindex,
  ogImageAlt,
  ogImageHeight,
  ogImageUrl,
  ogImageWidth,
  ogLocale,
  ogLocaleAlternates,
  pageDescription,
  servicesLabel,
  servicesNav,
  siteData,
  smsHref,
  socialDescription,
  socialTitle,
  structuredData,
  textDirection,
  title,
  ui,
  xDefaultHref,
} = layout;
---

<!doctype html>
<html lang={lang} dir={textDirection}>
		<head>
			<meta charset="utf-8" />
			<meta name="viewport" content="width=device-width" />
			<AnalyticsHead
				gtmAllowedOnPage={gtmAllowedOnPage}
				gtmId={gtmId}
				gtmPageContext={gtmPageContext}
			/>
			<SeoMetaHead
				generator={generator}
				title={title}
				pageDescription={pageDescription}
				noindex={noindex}
				canonicalUrl={canonicalUrl}
				brandName={brandName}
				socialTitle={socialTitle}
				socialDescription={socialDescription}
				ogLocale={ogLocale}
				ogLocaleAlternates={ogLocaleAlternates}
				ogImageUrl={ogImageUrl}
				ogImageWidth={ogImageWidth}
				ogImageHeight={ogImageHeight}
				ogImageAlt={ogImageAlt}
				hreflangLinks={hreflangLinks}
				xDefaultHref={xDefaultHref}
				structuredData={structuredData}
			/>
		</head>
		<body data-default-mailto-address={siteData.email} data-default-mailto-href={emailHref}>
			<AnalyticsBody gtmAllowedOnPage={gtmAllowedOnPage} gtmId={gtmId} />
			<a class="skip-link" href="#main-content">Skip to content</a>
			<SiteHeader
				brandLogo={brandLogo}
				brandName={brandName}
				canonicalPath={canonicalPath}
				currentLanguageLabel={currentLanguageLabel}
				emailHref={emailHref}
				languageLinks={languageLinks}
				localeBaseHref={localeBaseHref}
				mapsHref={mapsHref}
				desktopNav={desktopNav}
				mobilePrimaryNav={mobilePrimaryNav}
				mobileSecondaryNav={mobileSecondaryNav}
				servicesLabel={servicesLabel}
				servicesNav={servicesNav}
				site={siteData}
				smsHref={smsHref}
				ui={ui}
			/>
		<main id="main-content" class="page">
			<slot />
		</main>
			<SiteFooter
				brandName={brandName}
				emailHref={emailHref}
				locale={locale}
				mapsHref={mapsHref}
				navItems={navItems}
				site={siteData}
				smsHref={smsHref}
				ui={ui}
			/>
			<ChatWidget locale={locale} />
			<StickyCta emailHref={emailHref} site={siteData} smsHref={smsHref} ui={ui} />
			<SiteMenu
				canonicalPath={canonicalPath}
				emailHref={emailHref}
				navItems={navItems}
				siteEmail={siteData.email}
				ui={ui}
			/>
			<LanguageSwitcher
				links={languageLinks}
				ariaLabel={ui.languageLabel ?? 'Language'}
				id="lang-switcher"
				mode="panel"
			/>
			<BaseLayoutScripts />
		</body>
	</html>
