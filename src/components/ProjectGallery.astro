---
import type { LocaleKey, LocalizedText } from '../types/site';
import { getProject } from '../data/projects';
import { getPageLabel } from '../lib/site-data/page-registry.js';
import LightboxGallery from './LightboxGallery.astro';

interface Props {
  projectId: string;
  locale?: LocaleKey;
}

const { projectId, locale = 'en' } = Astro.props as Props;
const project = await getProject(projectId);

if (!project) {
  throw new Error(`Project not found: ${projectId}`);
}

const resolveCopy = (value?: LocalizedText) => value?.[locale] ?? value?.en ?? '';
const galleryTitle =
  resolveCopy(project.copy?.galleryTitle) || getPageLabel('gallery', locale) || 'See Our Work';
const images = project.images ?? [];
---

<section class="project-gallery">
	<div class="container">
		<h2>{galleryTitle}</h2>
		<LightboxGallery images={images} locale={locale} />
	</div>
</section>
<style>
	.project-gallery {
		padding: 2.5rem 0 3rem;
	}

	.project-gallery h2 {
		margin: 0;
		font-size: clamp(1.6rem, 2.4vw, 2.2rem);
	}
</style>
