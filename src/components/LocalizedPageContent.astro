---
import type { PageEntry, LocaleKey } from '../types/site';
import PageRenderer from '../features/page-rendering/PageRenderer.astro';

interface Props {
	entry: PageEntry;
	locale: LocaleKey;
}

const { entry, locale } = Astro.props as Props;

if (!entry) {
	throw new Error('LocalizedPageContent requires a content entry.');
}
---

<PageRenderer entry={entry} locale={locale} />
