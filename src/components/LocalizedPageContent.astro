---
import { render } from 'astro:content';
import ConvertibleTopMarqueAtlas from './ConvertibleTopMarqueAtlas.astro';
import FaqSection from './FaqSection.astro';
import FeaturedProject from './FeaturedProject.astro';
import LocalizedLink from './LocalizedLink.astro';
import PageHero from './PageHero.astro';
import PageShowcaseSections from './PageShowcaseSections.astro';
import ProjectPage from './ProjectPage.astro';
import ServiceCards from './ServiceCards.astro';

const { entry, locale } = Astro.props;

if (!entry) {
	throw new Error('LocalizedPageContent requires a content entry.');
}

const template = entry.data.template ?? 'standard';
const usesStructuredTemplate = template === 'project' || Boolean(entry.data.hero);

const rendered = template === 'project' ? null : await render(entry);
const RenderedContent = rendered?.Content ?? null;
const contentComponents = {
	...(rendered?.components ?? {}),
	ConvertibleTopMarqueAtlas,
	FaqSection,
	FeaturedProject,
	LocalizedLink,
	PageHero,
	PageShowcaseSections,
	ProjectPage,
	ServiceCards,
};
const pageModules = entry.data.pageModules ?? [];
---

{template === 'project' && entry.data.projectId ? (
	<ProjectPage projectId={entry.data.projectId} locale={locale} />
) : usesStructuredTemplate ? (
	<>
		{entry.data.hero ? (
			<PageHero
				locale={locale}
				title={entry.data.hero.title}
				lead={entry.data.hero.lead}
				kicker={entry.data.hero.kicker}
				showTrust={entry.data.hero.showTrust}
			/>
		) : null}
		{entry.data.showServiceCards !== false ? (
			<ServiceCards locale={locale} currentKey={entry.data.serviceCardsCurrentKey} />
		) : null}
		{pageModules.map((module) => {
			if (module.type === 'featuredProject') {
				return <FeaturedProject projectId={module.projectId} locale={locale} />;
			}

			if (module.type === 'showcase') {
				return <PageShowcaseSections locale={locale} pageKey={module.pageKey} />;
			}

			return <ConvertibleTopMarqueAtlas locale={locale} />;
		})}
		{RenderedContent ? <RenderedContent components={contentComponents} /> : null}
		{entry.data.faq ? (
			<FaqSection heading={entry.data.faq.heading} faqs={entry.data.faq.items} />
		) : null}
	</>
) : RenderedContent ? (
	<RenderedContent components={contentComponents} />
) : null}
