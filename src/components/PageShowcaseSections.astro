---
import type {
	BeforeAfterPair,
	GalleryImage,
	LocaleKey,
	LocalizedText,
	ShowcaseSectionWithMedia,
} from '../types/site';
import { getShowcaseSections } from '../data/galleries/page-showcase.js';
import BeforeAfterPairGrid from './BeforeAfterPairGrid.astro';
import LightboxGallery from './LightboxGallery.astro';

interface Props {
	locale?: LocaleKey;
	showcaseId: string;
}

const { locale = 'en', showcaseId } = Astro.props as Props;
const sections = (await getShowcaseSections(showcaseId)) as ShowcaseSectionWithMedia[];
const resolveCopy = (value?: LocalizedText) => value?.[locale] ?? value?.en ?? '';
---

{sections.map((section: ShowcaseSectionWithMedia) =>
	section.type === 'beforeAfter' ? (
		<BeforeAfterPairGrid
			pairs={(section.pairs ?? []) as BeforeAfterPair[]}
			locale={locale}
			label={resolveCopy(section.title)}
		/>
	) : (
		<section class="page-showcase" aria-label={resolveCopy(section.title)}>
			{resolveCopy(section.title) ? <h2>{resolveCopy(section.title)}</h2> : null}
			<LightboxGallery images={(section.images ?? []) as GalleryImage[]} locale={locale} />
		</section>
	),
)}

<style>
	.page-showcase {
		padding: 2.25rem 0;
	}

	.page-showcase h2 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.35rem, 2vw, 1.9rem);
	}

	.page-showcase h2 + .lightbox-gallery {
		margin-bottom: 2rem;
	}

	.page-showcase .lightbox-gallery {
		margin-bottom: 0;
	}
</style>
