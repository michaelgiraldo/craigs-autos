---
import LightboxGallery from './LightboxGallery.astro';
import BeforeAfterPairGrid from './BeforeAfterPairGrid.astro';
import {
	BEFORE_AFTER_SHOWCASE_PAIRS,
	SHOWCASE_COPY,
	getCarSeatsAllImages,
	getHomeShowcaseImages,
	getMotorcycleSeatHighlightImages,
	getServiceGalleryHighlightImages,
} from '../data/galleries/page-showcase.js';

const { locale = 'en', pageKey = 'home' } = Astro.props;
const resolveCopy = (value) => value?.[locale] ?? value?.en ?? '';
const copy = SHOWCASE_COPY[pageKey] ?? {};
const homeShowcaseImages = pageKey === 'home' ? await getHomeShowcaseImages() : [];
const carSeatsAllImages = pageKey === 'carSeats' ? await getCarSeatsAllImages() : [];
const serviceGalleryHighlightImages =
	pageKey === 'gallery' ? await getServiceGalleryHighlightImages() : [];
const motorcycleSeatHighlightImages =
	pageKey === 'motorcycleSeats' ? await getMotorcycleSeatHighlightImages() : [];
---

{pageKey === 'home' ? (
	<section class="page-showcase" aria-label={resolveCopy(copy.title)}>
		<h2>{resolveCopy(copy.title)}</h2>
		<LightboxGallery images={homeShowcaseImages} locale={locale} />
	</section>
) : null}

{pageKey === 'carSeats' ? (
	<section class="page-showcase" aria-label={resolveCopy(copy.highlightTitle)}>
		<h2>{resolveCopy(copy.highlightTitle)}</h2>
		<LightboxGallery images={carSeatsAllImages} locale={locale} />
	</section>
) : null}

{pageKey === 'gallery' ? (
	<section class="page-showcase" aria-label={resolveCopy(copy.highlightTitle)}>
		<h2>{resolveCopy(copy.highlightTitle)}</h2>
		<LightboxGallery images={serviceGalleryHighlightImages} locale={locale} />
	</section>
) : null}

{pageKey === 'carSeats' ? (
	<BeforeAfterPairGrid
		pairs={BEFORE_AFTER_SHOWCASE_PAIRS}
		locale={locale}
		label={resolveCopy(copy.beforeAfterTitle)}
	/>
) : null}

{pageKey === 'gallery' ? (
	<BeforeAfterPairGrid
		pairs={BEFORE_AFTER_SHOWCASE_PAIRS}
		locale={locale}
		label={resolveCopy(copy.beforeAfterTitle)}
	/>
) : null}

{pageKey === 'motorcycleSeats' ? (
	<section class="page-showcase" aria-label={resolveCopy(copy.highlightTitle)}>
		<h2>{resolveCopy(copy.highlightTitle)}</h2>
		<LightboxGallery images={motorcycleSeatHighlightImages} locale={locale} />
	</section>
) : null}

<style>
	.page-showcase {
		padding: 2.25rem 0;
	}

	.page-showcase h2 {
		margin: 0 0 0.75rem;
		font-size: clamp(1.35rem, 2vw, 1.9rem);
	}

	.page-showcase h2 + .lightbox-gallery {
		margin-bottom: 2rem;
	}

	.page-showcase .lightbox-gallery {
		margin-bottom: 0;
	}
</style>
