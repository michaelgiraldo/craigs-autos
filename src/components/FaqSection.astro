---
import type { PageFaqItem } from '../types/site';

interface Props {
	faqs?: PageFaqItem[];
	heading?: string;
	id?: string;
}

const { faqs = [], heading = 'FAQs', id = 'faqs' } = Astro.props as Props;

// SEO note: FAQPage JSON-LD must match the visible questions/answers.
const faqStructuredData =
	faqs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faqs.map((item: PageFaqItem) => ({
					'@type': 'Question',
					name: item.q,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.a,
					},
				})),
			}
		: null;
---

{faqs.length > 0 ? (
		<section class="faq" aria-labelledby={id}>
		<h2 id={id}>{heading}</h2>
		<div class="faq__list">
			{faqs.map((item: PageFaqItem) => (
				<details class="faq__item">
					<summary class="faq__question">{item.q}</summary>
					<div class="faq__answer">
						<p>{item.a}</p>
					</div>
				</details>
			))}
			</div>
			<script is:inline type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
		</section>
	) : null}
