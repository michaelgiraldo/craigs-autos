---
import { getCollection } from 'astro:content';
import type { PageEntry, LocaleKey } from '../../types/site';
import LocalizedPageContent from '../../components/LocalizedPageContent.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { LOCALES } from '../../lib/site-data.js';
import { getTranslations, resolveLocaleKey } from '../../lib/site-data/page-registry.js';

export async function getStaticPaths() {
	const entries = await getCollection('pages');
	const indexEntries = entries.filter((entry) => entry.data.slug === 'index');

	return indexEntries.map((entry) => {
		return {
			params: { lang: entry.data.locale },
			props: { entry },
		};
	});
}

interface Props {
	entry: PageEntry;
}

const { entry } = Astro.props as Props;
const locale = resolveLocaleKey(entry.data.locale) as LocaleKey;
const pageKey = entry.data.pageKey;
const translations = getTranslations(pageKey);
const canonicalPath = translations?.[locale] ?? `/${locale}/`;
const lang = LOCALES[locale]?.lang ?? LOCALES.en.lang;
const noindex = entry.data.noindex ?? false;
const disableLeadWidgets = entry.data.pageType === 'job';
const disableCustomerContactActions = entry.data.pageType === 'job';
---

<BaseLayout
	title={entry.data.title}
	description={entry.data.description}
	locale={locale}
	lang={lang}
	pageKey={pageKey}
	canonicalPath={canonicalPath}
	translations={translations}
	noindex={noindex}
	disableLeadWidgets={disableLeadWidgets}
	disableCustomerContactActions={disableCustomerContactActions}
>
	<LocalizedPageContent entry={entry} locale={locale} />
</BaseLayout>
