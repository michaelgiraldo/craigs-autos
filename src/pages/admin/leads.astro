---
import AdminLayout from '../../layouts/AdminLayout.astro';

const title = "Admin | Leads";
const description = "Lead qualification dashboard.";
---
<AdminLayout title={title} description={description}>
  <section class="admin-leads" aria-labelledby="admin-leads-title">
    <h1 id="admin-leads-title">Lead Qualification</h1>
    <p class="admin-leads__subtitle">
      Password protected. Mark qualified leads so they can be uploaded to Google Ads.
    </p>
    <div id="admin-leads-app" class="admin-leads__app"></div>
  </section>
  <script>
    import { initAdminLeads } from '../../scripts/admin-leads.ts';

    initAdminLeads();
  </script>
</AdminLayout>
