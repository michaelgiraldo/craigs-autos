<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Send customer message</title>
    <style>
      :root {
        --bg: #f6f7f9;
        --card: #ffffff;
        --text: #111827;
        --muted: #6b7280;
        --border: #e5e7eb;
        --accent: #141cff;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        padding: 24px;
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      }
      .wrap {
        max-width: 720px;
        margin: 0 auto;
      }
      h1 {
        margin: 0 0 8px;
        font-size: 20px;
        line-height: 1.2;
      }
      p {
        margin: 0 0 16px;
        color: var(--muted);
        line-height: 1.4;
        font-size: 14px;
      }
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 0 0 16px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--card);
        color: var(--text);
        font-size: 13px;
        line-height: 1;
        text-decoration: none;
        cursor: pointer;
      }
      .btn--primary {
        background: var(--accent);
        border-color: var(--accent);
        color: #ffffff;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 16px;
      }
      .label {
        font-size: 12px;
        color: var(--muted);
        margin: 0 0 6px;
      }
      .value {
        margin: 0 0 14px;
        font-size: 14px;
        line-height: 1.4;
        color: var(--text);
        word-break: break-word;
        white-space: pre-wrap;
      }
      pre.value {
        font-family: inherit;
      }
      details {
        margin-top: 14px;
      }
      summary {
        cursor: pointer;
        color: var(--muted);
        font-size: 13px;
      }
      .hint {
        margin-top: 10px;
        font-size: 13px;
        color: var(--muted);
        line-height: 1.4;
      }
      .error {
        color: #b91c1c;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <h1>Send customer message</h1>
      <p id="status">Preparing your draft...</p>

      <div class="actions">
        <a id="open-sms" class="btn btn--primary" href="#">Send via SMS</a>
        <a id="call" class="btn" href="#">Call</a>
        <button id="copy-phone" class="btn" type="button">Copy phone</button>
        <button id="copy-body" class="btn" type="button">Copy message</button>
      </div>

      <div class="card">
        <div class="label">To</div>
        <div id="to" class="value">-</div>

        <div class="label">Message</div>
        <pre id="body" class="value">-</pre>
      </div>

      <details>
        <summary>Having trouble?</summary>
        <div class="hint">
          If a channel doesn't open, use "Copy message" and paste the draft manually.
        </div>
      </details>
    </main>

    <script>
      import { initMessageLinkPage } from '../../scripts/message-link';

      void initMessageLinkPage();
    </script>
  </body>
</html>
