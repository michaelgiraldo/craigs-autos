---
import LocalizedLink from '../../../components/LocalizedLink.astro';
import type { LocaleKey } from '../../../types/site';

interface Props {
	locale: LocaleKey;
}

type HiringContactCalloutCopy = {
	ariaLabel: string;
	eyebrow: string;
	body: string;
	link: string;
};

const COPY: Record<LocaleKey, HiringContactCalloutCopy> = {
	en: {
		ariaLabel: 'Hiring information',
		eyebrow: 'Hiring note',
		body: "Looking for work? Craig's is hiring an experienced auto upholstery technician in San Jose. Applicants should use the hiring page and dedicated hiring line instead of the customer quote channels.",
		link: 'Experienced Auto Upholstery Technician job in San Jose',
	},
	es: {
		ariaLabel: 'Información de contratación',
		eyebrow: 'Nota de contratación',
		body: "¿Buscas trabajo? Craig's está contratando a un tapicero automotriz con experiencia en San José. Los candidatos deben usar la página de empleo y la línea de contratación dedicada en lugar de los canales para cotizaciones de clientes.",
		link: 'Trabajo de tapicero automotriz con experiencia en San José',
	},
