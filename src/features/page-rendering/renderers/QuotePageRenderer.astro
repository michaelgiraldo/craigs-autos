---
import QuotePage from '../../quote/components/QuotePage.astro';
import type { LocaleKey, PageEntry } from '../../../types/site';
import StructuredPageRenderer from './StructuredPageRenderer.astro';

interface Props {
	entry: PageEntry;
	locale: LocaleKey;
}

const { entry, locale } = Astro.props as Props;
---

<StructuredPageRenderer
	entry={entry}
	locale={locale}
	heroDisplay={{
		showActions: false,
		showHelper: false,
		showMeta: false,
		showTrust: false,
	}}
>
	<QuotePage slot="afterPageCardDeck" locale={locale} />
</StructuredPageRenderer>
