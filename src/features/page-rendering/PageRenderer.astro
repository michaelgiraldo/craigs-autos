---
import type { LocaleKey, PageEntry } from '../../types/site';
import JobPageRenderer from './renderers/JobPageRenderer.astro';
import ProjectPageRenderer from './renderers/ProjectPageRenderer.astro';
import QuotePageRenderer from './renderers/QuotePageRenderer.astro';
import StandardPageRenderer from './renderers/StandardPageRenderer.astro';

interface Props {
	entry: PageEntry;
	locale: LocaleKey;
}

const { entry, locale } = Astro.props as Props;
const pageType = entry.data.pageType;
---

{pageType === 'project' ? (
	<ProjectPageRenderer entry={entry} locale={locale} />
) : pageType === 'quote' ? (
	<QuotePageRenderer entry={entry} locale={locale} />
) : pageType === 'job' ? (
	<JobPageRenderer entry={entry} locale={locale} />
) : (
	<StandardPageRenderer entry={entry} locale={locale} />
)}
