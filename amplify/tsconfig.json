{
  "extends": "../tsconfig.runtime-base.json",
  "compilerOptions": {
    "target": "es2025",
    "lib": ["ES2025"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "paths": {
      "$amplify/*": ["../.amplify/generated/*"]
    }
  },
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "tests"]
}
